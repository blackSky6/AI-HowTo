---
import Base from '../layouts/Base.astro';
import HowToCard from '../components/HowToCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('how-to');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = sortedPosts.filter(p => p.data.featured).slice(0, 6);
const recentPosts = sortedPosts.slice(0, 12);

const categories = [
  { name: 'Writing & Emails', emoji: '✍️', href: '/category/writing', tag: 'writing' },
  { name: 'Image & Art', emoji: '🎨', href: '/category/image', tag: 'image' },
  { name: 'Coding', emoji: '💻', href: '/category/coding', tag: 'coding' },
  { name: 'Video & Audio', emoji: '🎬', href: '/category/video', tag: 'video' },
  { name: 'Productivity', emoji: '⚡', href: '/category/productivity', tag: 'productivity' },
  { name: 'Analysis & Data', emoji: '📊', href: '/category/data', tag: 'data' },
];
---

<Base
  title="AI HowTo Hub — Learn How to Use AI Tools Step by Step"
  description="Practical step-by-step guides to help you use AI tools effectively. From writing emails to generating images — we test the tools so you don't have to."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-indigo-600 via-indigo-700 to-purple-800 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 text-sm font-medium mb-6">
        <span>🔥</span> Practical AI tutorials, updated weekly
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold leading-tight mb-6">
        How to Use AI<br />
        <span class="text-indigo-200">for Anything</span>
      </h1>
      <p class="text-xl text-indigo-100 mb-8 max-w-2xl mx-auto">
        Step-by-step guides for real tasks. We test every tool so you get honest recommendations.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/how-to" class="bg-white text-indigo-700 font-bold px-7 py-3 rounded-xl hover:bg-indigo-50 transition-colors">
          Browse All Tutorials →
        </a>
        <a href="/tools" class="border border-white/30 text-white font-medium px-7 py-3 rounded-xl hover:bg-white/10 transition-colors">
          Explore AI Tools
        </a>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Browse by Category</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-3">
      {categories.map((cat) => (
        <a
          href={cat.href}
          class="flex flex-col items-center gap-2 bg-white border border-gray-200 rounded-xl p-4 hover:border-indigo-300 hover:shadow-sm transition-all text-center"
        >
          <span class="text-2xl">{cat.emoji}</span>
          <span class="text-xs font-medium text-gray-700">{cat.name}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured / Recent Posts -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-900">Latest Tutorials</h2>
      <a href="/how-to" class="text-indigo-600 hover:text-indigo-800 font-medium text-sm">View all →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {recentPosts.map((post) => (
        <HowToCard
          title={post.data.title}
          description={post.data.description}
          href={`/how-to/${post.id}`}
          tags={post.data.tags}
          readingTime={post.data.readingTime || '5 min'}
          tools={post.data.tools}
        />
      ))}
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-indigo-600 text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-3">Get Weekly AI Tips</h2>
      <p class="text-indigo-200 mb-6">New tutorials every week. No spam. Unsubscribe anytime.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 rounded-lg text-gray-900 border-0 focus:ring-2 focus:ring-white"
        />
        <button
          type="submit"
          class="bg-white text-indigo-700 font-bold px-6 py-3 rounded-lg hover:bg-indigo-50 transition-colors whitespace-nowrap"
        >
          Subscribe Free
        </button>
      </form>
    </div>
  </section>
</Base>
