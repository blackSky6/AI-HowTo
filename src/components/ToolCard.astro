---
export interface Props {
  name: string;
  description: string;
  rating: number;
  affiliateUrl: string;
  badge?: string;
  pricing?: string;
}

const { name, description, rating, affiliateUrl, badge = 'Top Pick', pricing } = Astro.props;

const stars = Math.round(rating);
---

<div class="bg-gradient-to-r from-indigo-50 to-purple-50 border border-indigo-200 rounded-xl p-6 my-8">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-2">
        <span class="bg-indigo-600 text-white text-xs font-bold px-2.5 py-1 rounded-full">
          ⭐ {badge}
        </span>
        {pricing && (
          <span class="text-xs text-gray-600 bg-white border border-gray-200 px-2.5 py-1 rounded-full">
            {pricing}
          </span>
        )}
      </div>
      <h3 class="text-xl font-bold text-gray-900 mb-1">{name}</h3>
      <div class="flex items-center gap-1 mb-2">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg
            class={`w-4 h-4 ${i < stars ? 'text-yellow-400' : 'text-gray-300'}`}
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
        <span class="text-sm text-gray-600 ml-1">{rating}/5</span>
      </div>
      <p class="text-gray-700">{description}</p>
    </div>
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class="flex-shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm whitespace-nowrap"
    >
      Try Free →
    </a>
  </div>
</div>
