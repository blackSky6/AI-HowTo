---
export interface Tool {
  name: string;
  price: string;
  free: boolean;
  quality: string;
  speed: string;
  easeOfUse: string;
  affiliateUrl: string;
  pros: string[];
  cons: string[];
}

export interface Props {
  tools: Tool[];
}

const { tools } = Astro.props;
---

<div class="overflow-x-auto my-8">
  <table class="w-full border-collapse bg-white rounded-xl overflow-hidden shadow-sm border border-gray-200">
    <thead>
      <tr class="bg-gray-50">
        <th class="text-left px-4 py-3 text-sm font-semibold text-gray-700 border-b border-gray-200">Tool</th>
        <th class="text-left px-4 py-3 text-sm font-semibold text-gray-700 border-b border-gray-200">Price</th>
        <th class="text-left px-4 py-3 text-sm font-semibold text-gray-700 border-b border-gray-200">Quality</th>
        <th class="text-left px-4 py-3 text-sm font-semibold text-gray-700 border-b border-gray-200">Speed</th>
        <th class="text-left px-4 py-3 text-sm font-semibold text-gray-700 border-b border-gray-200">Ease of Use</th>
        <th class="text-left px-4 py-3 text-sm font-semibold text-gray-700 border-b border-gray-200">Best For</th>
      </tr>
    </thead>
    <tbody>
      {tools.map((tool, i) => (
        <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
          <td class="px-4 py-3 border-b border-gray-100">
            <a href={tool.affiliateUrl} target="_blank" rel="noopener nofollow"
               class="font-medium text-indigo-600 hover:text-indigo-800">
              {tool.name}
            </a>
            {tool.free && (
              <span class="ml-1.5 text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">Free tier</span>
            )}
          </td>
          <td class="px-4 py-3 border-b border-gray-100 text-sm text-gray-700">{tool.price}</td>
          <td class="px-4 py-3 border-b border-gray-100 text-sm text-gray-700">{tool.quality}</td>
          <td class="px-4 py-3 border-b border-gray-100 text-sm text-gray-700">{tool.speed}</td>
          <td class="px-4 py-3 border-b border-gray-100 text-sm text-gray-700">{tool.easeOfUse}</td>
          <td class="px-4 py-3 border-b border-gray-100 text-sm text-gray-700">
            <ul class="space-y-0.5">
              {tool.pros.slice(0, 2).map((pro) => (
                <li class="flex items-start gap-1">
                  <span class="text-green-500 mt-0.5">✓</span>
                  <span>{pro}</span>
                </li>
              ))}
            </ul>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
