---
import Base from './Base.astro';
import ToolCard from '../components/ToolCard.astro';
import FAQ from '../components/FAQ.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tools?: string[];
  topTool?: {
    name: string;
    description: string;
    rating: number;
    affiliateUrl: string;
    badge?: string;
    pricing?: string;
  };
  faq?: Array<{ question: string; answer: string }>;
  relatedPosts?: Array<{ title: string; href: string }>;
  howToSchema?: {
    name: string;
    description: string;
    steps: Array<{ name: string; text: string }>;
  };
}

const {
  title,
  description,
  pubDate,
  tools = [],
  topTool,
  faq = [],
  relatedPosts = [],
  howToSchema,
} = Astro.props;

const schema = howToSchema ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": howToSchema.name,
  "description": howToSchema.description,
  "step": howToSchema.steps.map((step, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": step.name,
    "text": step.text,
  })),
} : null;

const readingTime = "5 min read";
---

<Base title={title} description={description} pubDate={pubDate} type="article">
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span>/</span>
      <a href="/how-to" class="hover:text-indigo-600">Tutorials</a>
      <span>/</span>
      <span class="text-gray-700 truncate">{title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight mb-4">{title}</h1>
      <p class="text-lg text-gray-600 mb-4">{description}</p>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>·</span>
        <span>{readingTime}</span>
        {tools.length > 0 && (
          <>
            <span>·</span>
            <span>Tools: {tools.slice(0, 3).join(', ')}</span>
          </>
        )}
      </div>
    </header>

    <!-- Top Pick Tool Card -->
    {topTool && (
      <ToolCard
        name={topTool.name}
        description={topTool.description}
        rating={topTool.rating}
        affiliateUrl={topTool.affiliateUrl}
        badge={topTool.badge}
        pricing={topTool.pricing}
      />
    )}

    <!-- Article Content -->
    <div class="prose prose-indigo max-w-none">
      <slot />
    </div>

    <!-- FAQ Section -->
    {faq.length > 0 && <FAQ items={faq} />}

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <aside class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Related Tutorials</h2>
        <ul class="space-y-2">
          {relatedPosts.map((post) => (
            <li>
              <a href={post.href} class="flex items-center gap-2 text-indigo-600 hover:text-indigo-800 font-medium text-sm">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
                {post.title}
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>

  <!-- JSON-LD HowTo Schema -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</Base>
